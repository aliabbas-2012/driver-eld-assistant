{
  "info": {
    "_postman_id": "a1b2c3d4-eld-assistant-api",
    "name": "Driver ELD Assistant API",
    "description": "Django REST + JWT + trip planning. Run `python manage.py seed_demo` then login demodriver / demo12345.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access", "value": "" },
    { "key": "refresh", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/health/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register (new carrier)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newdriver1\",\n  \"email\": \"newdriver1@example.com\",\n  \"password\": \"SecurePass123\",\n  \"password_confirm\": \"SecurePass123\",\n  \"first_name\": \"Taylor\",\n  \"last_name\": \"Smith\",\n  \"cdl_number\": \"W9876543\",\n  \"license_state\": \"WI\",\n  \"carrier\": {\n    \"name\": \"North Star Transport\",\n    \"main_office_address\": \"100 Main St, Milwaukee, WI 53202\",\n    \"home_terminal_address\": \"200 Depot Rd, Milwaukee, WI 53204\"\n  }\n}"
            },
            "url": "{{base_url}}/api/auth/register/"
          }
        },
        {
          "name": "POST Register (carrier_id)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newdriver2\",\n  \"email\": \"newdriver2@example.com\",\n  \"password\": \"SecurePass123\",\n  \"password_confirm\": \"SecurePass123\",\n  \"first_name\": \"Casey\",\n  \"last_name\": \"Jones\",\n  \"cdl_number\": \"J5554443\",\n  \"license_state\": \"IL\",\n  \"carrier_id\": 1\n}"
            },
            "url": "{{base_url}}/api/auth/register/"
          }
        },
        {
          "name": "POST Token (login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access) { pm.collectionVariables.set('access', json.access); }",
                  "if (json.refresh) { pm.collectionVariables.set('refresh', json.refresh); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demodriver\",\n  \"password\": \"demo12345\"\n}"
            },
            "url": "{{base_url}}/api/auth/token/"
          }
        },
        {
          "name": "POST Token refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}" },
            "url": "{{base_url}}/api/auth/token/refresh/"
          }
        }
      ]
    },
    {
      "name": "Planning",
      "item": [
        {
          "name": "POST Geocode",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"address\": \"Chicago, IL\"\n}" },
            "url": "{{base_url}}/api/geocode/"
          }
        },
        {
          "name": "POST Route",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_location\": \"Chicago, IL\",\n  \"pickup_location\": \"Indianapolis, IN\",\n  \"dropoff_location\": \"Atlanta, GA\"\n}"
            },
            "url": "{{base_url}}/api/route/"
          }
        },
        {
          "name": "POST Hours",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cycle_used_hours\": \"35\",\n  \"additional_on_duty_hours\": \"4\"\n}"
            },
            "url": "{{base_url}}/api/hours/"
          }
        },
        {
          "name": "POST Trips plan (full pipeline)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_location\": \"Chicago, IL\",\n  \"pickup_location\": \"Indianapolis, IN\",\n  \"dropoff_location\": \"Atlanta, GA\",\n  \"cycle_used_hours\": \"35\",\n  \"trip_start_date\": \"2026-05-12\",\n  \"vehicle_id\": 1,\n  \"trailer_id\": 1,\n  \"shipping_doc_number\": \"BOL-POSTMAN\",\n  \"shipper_name\": \"Demo Shipper\",\n  \"commodity\": \"Dry van\"\n}"
            },
            "url": "{{base_url}}/api/trips/plan/"
          }
        }
      ]
    },
