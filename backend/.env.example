# Use a long random string in production (JWT signing also uses SECRET_KEY).
DJANGO_SECRET_KEY=change-me-in-development
DJANGO_DEBUG=True
# Production: include your API hostname (e.g. my-api.onrender.com) — missing host → 400 and “CORS failed” in browser.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Browser Origin(s) allowed to call this API (comma or newline separated, no trailing slash).
# Must match exactly: https://your-app.vercel.app (add www variant separately if you use it).
# CORS_EXTRA_ORIGINS=https://driver-eld-assistant.vercel.app
# Optional second list merged the same way:
# CORS_ALLOWED_ORIGINS=https://preview-123.vercel.app

# Optional: one regex for all Vercel previews (less strict — use only if you accept any *.vercel.app calling your API).
# CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$

# Optional override (default 86400):
# CORS_PREFLIGHT_MAX_AGE=86400

# SQLite by default. For PostgreSQL:
# USE_POSTGRES=true
# POSTGRES_DB=eld_assistant
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secret
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
