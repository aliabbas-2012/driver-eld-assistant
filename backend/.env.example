# Use a long random string in production (JWT signing also uses SECRET_KEY).
DJANGO_SECRET_KEY=change-me-in-development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins for browser SPA (e.g. Vercel preview URL)
# CORS_EXTRA_ORIGINS=https://driver-eld-assistant.vercel.app

# SQLite by default. For PostgreSQL:
# USE_POSTGRES=true
# POSTGRES_DB=eld_assistant
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secret
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
